# ---- Stage 1: Build (demo) ----
# VITE_DEMO=1 makes the app serve canned data client-side (see src/utils/demo.js):
# no API, no collector, no socket. Safe to expose publicly with no password.
FROM node:22-alpine AS build
WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY . .
ENV VITE_DEMO=1
RUN npm run build:demo

# ---- Stage 2: Serve ----
FROM nginx:alpine
COPY --from=build /app/dist-demo /usr/share/nginx/html
COPY nginx.demo.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
