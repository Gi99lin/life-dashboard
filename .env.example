# ---- Garmin Connect ----
GARMIN_EMAIL=your@email.com
GARMIN_PASSWORD=your_password

# ---- Paths (host machine) ----
# Obsidian vault — read by API (schedule editor) and collector (daily notes, schedules)
VAULT_PATH=/home/gigglin/obsidian-vault

# Git repos directory — collector scans subdirectories with .git/ for commit tracking
GIT_REPOS_PATH=/home/gigglin/My_server

# ---- Weather ----
# Moscow coordinates
WEATHER_LAT=55.7558
WEATHER_LON=37.6173

# ---- Auth ----
DASHBOARD_PASS=your_password_here

# ---- Content redesign (new sources; optional — features degrade gracefully if unset) ----
# WakaTime: coding hours by language/project (collector)
WAKATIME_API_KEY=
# GitHub-deep: PRs / reviews / streak (collector)
GITHUB_TOKEN=
GITHUB_USER=
# CI status: latest GitHub Actions run per repo (collector). Comma-separated
# "owner/repo" (GITHUB_CI_REPOS accepted as an alias; reuses GITHUB_TOKEN).
CI_REPOS=
# Self-hosted LLM (OpenAI-compatible) for the AI daily brief (collector)
LLM_BASE_URL=https://your-llm-host/v1
LLM_API_KEY=
LLM_MODEL=

# ---- Infrastructure topology (optional; API degrades gracefully if unset) ----
# nginx config to parse public host -> proxy_pass routes
NGINX_CONF_PATH=
# Guacamole REST API for VM/open-via-Guacamole nodes
GUAC_URL=
GUAC_USER=
GUAC_PASS=
